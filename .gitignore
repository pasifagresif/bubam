yt-dlp/

# İndirilen / kesilen videolar
*.mp4
*.mkv
*.webm

# Linux'a özel statik ffmpeg ikilileri (Windows build'i CI içinde kendi indirir)
/ffmpeg
/ffprobe

# Python
__pycache__/
*.pyc
.venv/

# PyInstaller çıktıları
build/
dist/
*.spec
